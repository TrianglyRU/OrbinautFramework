/// @self obj_game
function scr_game_setup()
{
	// Change the rm_startup's size to set up the game's default
	// internal (application_surface) and camera resolution
	
	// 396x224 is Classics-like
	// 424x240 is Origins/Mania-like
	
	global.dev_mode = true;
	global.window_name = "ORBINAUT FRAMEWORK GAME";
	
	global.load_config_on_start = true;
	global.gamepad_rumble = false;
	global.music_volume = 0.5;
	global.sound_volume = 0.5;
	global.window_scale = 2;
	global.vsync = true;
	global.start_fullscreen = false;
	global.start_exclusive_fullscreen = true;
	global.start_room = rm_branding;
	
	global.player_physics = PHYSICS.S2;
	global.cpu_behaviour = CPU_BEHAVIOUR.S3;
	global.rotation_mode = ROTATION.MANIA;
	global.better_solid_collision = false;
	global.better_angle_snap = false;
	global.spin_dash = true;
	global.dash	= true;
	global.drop_dash = false;
	global.double_spin = true;
	global.cd_timer = false;
	global.cd_camera = false;
	global.roll_lock = true;
	global.speed_cap = false;
	global.roll_speed_cap = true;
	
	// Values set here will apply only if loading into the stage directly
	global.player_main = PLAYER.SONIC;
	global.player_cpu = PLAYER.TAILS;
	global.continue_count = 0;
	global.emerald_count = 0;
	global.score_count = 0;
	global.life_count = 3;
	
	// Ignored if dev_mode is enabled
	global.enable_debug_mode = false;
	
	// Use your own App ID here. Set to false instead of np_initdiscord to disable
	global.discord_ready = np_initdiscord("1286956015241265174", false, 0);
	
	#region FONTS
	
	font_register(spr_font_large, "ABCDEFGHIJKLMNOPQRSTUVWXYZ", true, 0);
	font_register(spr_font_large_alt, "ABCDEFGHIJKLMNOPQRSTUVWXYZ", true, 0);
	font_register(spr_font_small, "ABCDEFGHIJKLMNOPQRSTUVWXYZ1234567890*.:!-+_", false, 0);
	font_register(spr_font_digits, "0123456789:';", false, 1);
	font_register(spr_font_digits_alt, "0123456789:';", false, 1);
	font_register(spr_font_digits_small, "0123456789", false, 1);
	font_register(spr_font_system, "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ1234567890.:,;'(!?)+-*=_[]{}<>|#$%&^@~/", false, 0);
	
	#endregion
	
	#region AUDIO LOOPS
	
	audio_bgm_set_loop(snd_bgm_bonus_stage, 10.850, 39.850);
	audio_bgm_set_loop(snd_bgm_invincibility, 0.000, 10.300);
	audio_bgm_set_loop(snd_bgm_high_speed, 1.400, 27.370);
	audio_bgm_set_loop(snd_bgm_continue, 1.400, 11.150);
	audio_bgm_set_loop(snd_bgm_super_character, 0.307, 38.707);
	audio_bgm_set_loop(snd_bgm_special_stage, 1.710, 51.210);
